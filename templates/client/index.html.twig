{% extends 'layout/sidebar.html.twig' %}

{% block title %}Clients
{% endblock %}

{% block content %}

	<div class="flex items-center justify-between mb-6">
		<h1 class="text-2xl font-bold text-[#101828]">Clients</h1>
		<a href="{{ path('app_client_index', {'new': 1}) }}" class="flex items-center gap-2 bg-[#155DFC] text-white text-sm px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
			Ajouter un client
		</a>
	</div>

	{% if showForm %}
		<div class="bg-white rounded-[14px] border border-[#F3F4F6] p-6 mb-6 w-md mx-auto" style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">

			<div class="flex items-center justify-between mb-4">
				<h2 class="text-lg font-semibold text-[#101828]">
					{% if editingClient %}
						Client -
						{{ editingClient.name }}
						<p class="text-sm font-normal text-[#4A5565]">Modifier le client</p>
					{% else %}
						Nouveau client
					{% endif %}
				</h2>
				<a href="{{ path('app_client_index') }}" class="text-[#4A5565] hover:text-[#101828]">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
				</a>
			</div>

			{{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

			{# Nom #}
			<div class="flex flex-col gap-1 mb-4">
				<label class="text-[14px] font-normal text-[#364153]">Nom du client / Entreprise</label>
				{{ form_widget(form.name, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
				<span class="text-xs text-red-500">{{ form_errors(form.name) }}</span>
			</div>

			{# Email + Phone #}
			<div class="flex gap-4 mb-4">
				<div class="flex-1 flex flex-col gap-1">
					<label class="text-[14px] font-normal text-[#364153]">Email</label>
					{{ form_widget(form.email, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
					<span class="text-xs text-red-500">{{ form_errors(form.email) }}</span>
				</div>
				<div class="flex-1 flex flex-col gap-1">
					<label class="text-[14px] font-normal text-[#364153]">Téléphone</label>
					{{ form_widget(form.phone, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
					<span class="text-xs text-red-500">{{ form_errors(form.phone) }}</span>
				</div>
			</div>

			{# Adress #}
			<div class="flex flex-col gap-1 mb-4">
				<label class="text-[14px] font-normal text-[#364153]">Adresse</label>
				{{ form_widget(form.address, { attr: { class: 'w-full border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500', rows: '3' } }) }}
				<span class="text-xs text-red-500">{{ form_errors(form.address) }}</span>
			</div>

			{# SIRET + RIB #}
			<div class="flex gap-4 mb-6">
				<div class="flex-1 flex flex-col gap-1">
					<label class="text-[14px] font-normal text-[#364153]">SIRET (Optionnel)</label>
					{{ form_widget(form.siret, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
					<span class="text-xs text-red-500">{{ form_errors(form.siret) }}</span>
				</div>
				<div class="flex-1 flex flex-col gap-1">
					<label class="text-[14px] font-normal text-[#364153]">RIB</label>
					{{ form_widget(form.rib, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
					<span class="text-xs text-red-500">{{ form_errors(form.rib) }}</span>
				</div>
			</div>

			<div class="flex items-center gap-3 justify-end">
				<a href="{{ path('app_client_index') }}" class="px-4 py-2 text-sm text-[#4A5565] border border-[#D1D5DC] rounded-lg hover:bg-gray-50">
					Annuler
				</a>
				<button type="submit" class="px-4 py-2 bg-[#155DFC] text-white text-sm rounded-lg hover:bg-blue-700 transition-colors">
					Enregistrer
				</button>
			</div>

			{{ form_end(form) }}
		</div>
	{% endif %}

	{# List #}
	<div class="bg-white rounded-[14px] border border-[#F3F4F6]" style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">

		<div class="grid grid-cols-[1fr_1fr_2fr_100px] border-b border-[#F3F4F6] px-6 py-3">
			<span class="text-[14px] font-bold text-[#101828]">Nom</span>
			<span class="text-[14px] font-bold text-[#101828]">Contact</span>
			<span class="text-[14px] font-bold text-[#101828]">Adresse</span>
			<span class="text-[14px] font-bold text-[#101828] text-right">Actions</span>
		</div>

		{% for client in clients %}
			<div class="grid grid-cols-[1fr_1fr_2fr_100px] items-center px-6 border-b border-[#F3F4F6] last:border-b-0" style="min-height: 67px;">
				<span class="text-[16px] text-[#101828]">{{ client.name }}</span>
				<div>
					<p class="text-[14px] text-[#101828]">{{ client.email }}</p>
					<p class="text-[12px] text-[#4A5565]">{{ client.formattedPhone }}</p>
				</div>
				<span class="text-[14px] text-[#4A5565]">{{ client.formattedAddress }}</span>
				<div class="flex items-center justify-end gap-3">
					<a href="{{ path('app_client_index', {'edit': client.id}) }}">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="#155DFC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
					</a>
					<form method="post" action="{{ path('app_client_delete', {'id': client.id}) }}" onsubmit="return confirm('Supprimer ce client ?')">
						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
						<button type="submit" class="bg-transparent border-0 cursor-pointer p-0">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="#E7000B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
						</button>
					</form>
				</div>
			</div>
		{% else %}
			<div class="px-6 py-8 text-center text-[#4A5565]">
				Aucun client pour le moment.
				<a href="{{ path('app_client_index', {'new': 1}) }}" class="text-[#155DFC] hover:underline ml-1">Ajouter le premier</a>
			</div>
		{% endfor %}

	</div>

{% endblock %}
