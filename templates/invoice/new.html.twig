{% extends 'layout/sidebar.html.twig' %}

{% block title %}Créer une facture{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const addBtn = document.getElementById('add-item');
            const collection = document.getElementById('invoice-items');
            let index = collection.querySelectorAll('.invoice-item').length;

            addBtn.addEventListener('click', function () {
                const prototype = collection.dataset.prototype;
                const newItem = prototype.replace(/__name__/g, index);
                const div = document.createElement('div');
                div.classList.add('invoice-item', 'grid', 'grid-cols-[2fr_1fr_40px]', 'gap-3', 'items-end');
                div.innerHTML = newItem + `
                    <button type="button" class="remove-item h-[42px] flex items-center justify-center text-[#E7000B] border border-[#E7000B] rounded-lg px-3 hover:bg-red-50">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    </button>`;
                collection.appendChild(div);
                index++;

                // Styliser new inputs
                styleItems();
            });

            // Supprimer une ligne
            document.addEventListener('click', function (e) {
                if (e.target.closest('.remove-item')) {
                    e.target.closest('.invoice-item').remove();
                    updateTotal();
                }
            });

            // Calcul in live
            document.addEventListener('change', function (e) {
                if (e.target.closest('#invoice-items')) {
                    updateTotal();
                }
            });

            function updateTotal() {
                let total = 0;
                document.querySelectorAll('.invoice-item').forEach(function (item) {
                    const select = item.querySelector('select');
                    const qty = item.querySelector('input[type="number"], input[id*="quantity"]');
                    if (select && qty && select.selectedIndex > 0) {
                        const price = parseFloat(select.options[select.selectedIndex].dataset.price || 0);
                        const quantity = parseInt(qty.value || 0);
                        total += price * quantity;
                    }
                });
                const totalEl = document.getElementById('total-display');
                if (totalEl) totalEl.textContent = total.toFixed(2) + ' €';
            }

            function styleItems() {
                document.querySelectorAll('.invoice-item select, .invoice-item input').forEach(function (el) {
                    el.classList.add('w-full', 'h-[42px]', 'border', 'border-[#D1D5DC]', 'rounded-lg', 'px-3', 'py-2', 'text-sm', 'focus:outline-none', 'focus:ring-2', 'focus:ring-blue-500');
                });
            }

            styleItems();
        });
    </script>
{% endblock %}

{% block content %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-[#101828]">Créer une facture</h1>
    <a href="{{ path('app_invoice_index') }}" class="text-sm text-[#4A5565] hover:text-[#101828]">← Retour</a>
</div>

{{ form_start(form, { attr: { novalidate: 'novalidate', id: 'invoice-form' } }) }}

<div class="grid grid-cols-[2fr_1fr] gap-6">

    {# Left #}
    <div class="flex flex-col gap-6">

        {# Client #}
        <div class="bg-white rounded-[14px] border border-[#F3F4F6] p-6"
             style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">
            <h2 class="text-base font-semibold text-[#101828] mb-4">Client</h2>
            <div class="flex flex-col gap-1">
                <label class="text-[14px] font-normal text-[#364153]">Client</label>
                {{ form_widget(form.client, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
                <span class="text-xs text-red-500">{{ form_errors(form.client) }}</span>
            </div>
        </div>

        {# Products / Services #}
        <div class="bg-white rounded-[14px] border border-[#F3F4F6] p-6"
             style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">
            <h2 class="text-base font-semibold text-[#101828] mb-4">Produits / Services</h2>

            {# Header colonnes #}
            <div class="grid grid-cols-[2fr_1fr_40px] gap-3 mb-2">
                <span class="text-[14px] font-bold text-[#101828]">Produit</span>
                <span class="text-[14px] font-bold text-[#101828]">Quantité</span>
                <span></span>
            </div>

            {# Collection #}
            <div id="invoice-items"
                 data-prototype="{{ form_widget(form.invoiceItems.vars.prototype) | e('html_attr') }}">
                {% for item in form.invoiceItems %}
                    <div class="invoice-item grid grid-cols-[2fr_1fr_40px] gap-3 items-end mb-3">
                        {{ form_widget(item.product, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
                        {{ form_widget(item.quantity, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
                        <button type="button" class="remove-item h-[42px] flex items-center justify-center text-[#E7000B] border border-[#E7000B] rounded-lg px-3 hover:bg-red-50">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                        </button>
                    </div>
                {% endfor %}
            </div>

            <button type="button" id="add-item"
                    class="flex items-center gap-2 text-[#155DFC] text-sm hover:underline mt-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                Ajouter une ligne
            </button>
        </div>

    </div>

    {# Right #}
    <div class="flex flex-col gap-6">

        {# Statut #}
        <div class="bg-white rounded-[14px] border border-[#F3F4F6] p-6"
             style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">
            <h2 class="text-base font-semibold text-[#101828] mb-4">Statut</h2>
            <div class="flex flex-col gap-1">
                {{ form_widget(form.status, { attr: { class: 'w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500' } }) }}
                <span class="text-xs text-red-500">{{ form_errors(form.status) }}</span>
            </div>
        </div>

        {# Total #}
        <div class="bg-white rounded-[14px] border border-[#F3F4F6] p-6"
             style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">
            <h2 class="text-base font-semibold text-[#101828] mb-2">Total TTC</h2>
            <p class="text-3xl font-bold text-[#101828]" id="total-display">0.00 €</p>
            <p class="text-xs text-[#4A5565] mt-1">Calculé automatiquement</p>
        </div>

        {# Boutons #}
        <div class="flex flex-col gap-3">
            <button type="submit"
                    class="w-full py-2.5 bg-[#155DFC] text-white text-sm rounded-lg hover:bg-blue-700 transition-colors">
                Enregistrer la facture
            </button>
            <a href="{{ path('app_invoice_index') }}"
               class="w-full py-2.5 text-center text-sm text-[#4A5565] border border-[#D1D5DC] rounded-lg hover:bg-gray-50">
                Annuler
            </a>
        </div>

    </div>

</div>

{{ form_end(form) }}

{% endblock %}