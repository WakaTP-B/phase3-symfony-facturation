{% extends 'base.html.twig' %}

{% block title %}
	Connexion
{% endblock %}

{% block body %}
	<div
		class="min-h-screen bg-gray-50 flex flex-col items-center justify-center">

		{# Header #}
		<div class="text-center mb-8">
			<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewbox="0 0 24 24" fill="none" stroke="#155DFC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2">
				<path d="M12 17V7"/>
				<path d="M16 8h-6a2 2 0 0 0 0 4h4a2 2 0 0 1 0 4H8"/>
				<path d="M4 3a1 1 0 0 1 1-1 1.3 1.3 0 0 1 .7.2l.933.6a1.3 1.3 0 0 0 1.4 0l.934-.6a1.3 1.3 0 0 1 1.4 0l.933.6a1.3 1.3 0 0 0 1.4 0l.933-.6a1.3 1.3 0 0 1 1.4 0l.934.6a1.3 1.3 0 0 0 1.4 0l.933-.6A1.3 1.3 0 0 1 19 2a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1 1.3 1.3 0 0 1-.7-.2l-.933-.6a1.3 1.3 0 0 0-1.4 0l-.934.6a1.3 1.3 0 0 1-1.4 0l-.933-.6a1.3 1.3 0 0 0-1.4 0l-.933.6a1.3 1.3 0 0 1-1.4 0l-.934-.6a1.3 1.3 0 0 0-1.4 0l-.933.6a1.3 1.3 0 0 1-.7.2 1 1 0 0 1-1-1z"/></svg>
			<h1 class="text-2xl font-bold text-gray-900">Connectez-vous</h1>
			<p class="text-sm text-gray-500 mt-1">
				Ou
				<a href="{{ path('app_register') }}" class="text-blue-600 hover:underline">créez un compte gratuitement</a>
			</p>
		</div>

		{# Formulaire #}
		<div class="bg-white rounded-[10px] w-md px-10 pt-8 pb-8" style="box-shadow: 0 1px 2px rgba(0,0,0,0.10), 0 3px 0px -1px rgba(0,0,0,0.10);">

			<form
				method="post">

				{# Email #}
				<div class="flex flex-col gap-1 mb-6">
					<label class="text-[14px] font-normal text-[#364153]">Adresse Email</label>
					<input type="email" name="_username" value="{{ last_username }}" autocomplete="email" class="w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
				</div>

				{# Password #}
				<div class="flex flex-col gap-1 mb-6">
					<label class="text-[14px] font-normal text-[#364153]">Mot de passe</label>
					<input type="password" name="_password" autocomplete="current-password" class="w-full h-[42px] border border-[#D1D5DC] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
				</div>

				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

				{% if error %}
					<div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">
						{{ error.messageKey | trans(error.messageData, 'security') }}
					</div>
				{% endif %}

				<button type="submit" class="w-full h-[38px] bg-[#155DFC] text-white text-sm rounded-lg hover:bg-blue-700 transition-colors">
					Se connecter
				</button>
			</form>
		</div>
	</div>
{% endblock %}
